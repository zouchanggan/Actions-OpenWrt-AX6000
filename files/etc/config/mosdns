
config mosdns 'config'
	option listen_port '5335'
	option geo_update_week_time '*'
	option geo_update_day_time '2'
	option logfile '/tmp/mosdns.log'
	option cache_size '8000'
	option cache_survival_time '86400'
	option idle_timeout '30'
	option minimal_ttl '0'
	option maximum_ttl '0'
	option enable_http3_remote '0'
	option listen_port_api '9091'
	option enable_ecs_remote '0'
	option enable_pipeline '1'
	option geo_auto_update '1'
	option dump_file '1'
	option dump_interval '3600'
	option custom_local_dns '1'
	option apple_optimization '1'
	option concurrent '2'
	option bootstrap_dns '119.29.29.29'
	option cloudflare '0'
	option log_level 'info'
	option max_conns '2'
	option prefer_ipv4 '1'
	option dns_leak '1'
	option adblock '1'
	list ad_source 'https://raw.githubusercontent.com/Loyalsoldier/v2ray-rules-dat/release/reject-list.txt'
	option insecure_skip_verify '0'
	list remote_dns 'https://doh.apad.pro/dns-query'
	option redirect '1'
	option configfile '/var/etc/mosdns.json'
	option log_file '/var/log/mosdns.log'
	list local_dns '202.96.128.86'
	list local_dns '202.96.134.33'
	option lazy_cache_ttl '86400'
	option enabled '0'

